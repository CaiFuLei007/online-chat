# ============================================================================
# online-chat 环境变量模板
#
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env 填入你自己的配置
#
# 说明：
#   - .env 文件已被 .gitignore 排除，不会提交到版本库
#   - 所有变量在 docker-compose.yml 中有默认值，但 SMTP 和 JWT_SECRET 必须填写
# ============================================================================

# ── JWT 密钥（必填）─────────────────────────────────────
# 用于签发和验证 JWT token，建议使用随机字符串
# 生成方法：openssl rand -base64 32
JWT_SECRET=

# ── SMTP 邮件服务（必填，用于发送注册验证码）─────────────
# 以下以 QQ 邮箱为例，其他邮箱请查阅对应 SMTP 配置
# QQ 邮箱 SMTP 授权码获取：设置 → 账户 → POP3/SMTP 服务 → 开启后获取授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM_EMAIL=your-email@qq.com

# ── MySQL（可选，有默认值）───────────────────────────────
# MYSQL_ROOT_PASSWORD=root_pwd_dev
# MYSQL_DATABASE=online_chat
# MYSQL_USER=online_chat
# MYSQL_PASSWORD=online_chat_pwd

# ── 代理（可选，国内用户构建 Docker 镜像时可能需要）──────
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
